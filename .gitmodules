[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "codebook"]
	path = codebook
	url = https://github.com/rubenarslan/codebook
[submodule "formr"]
	path = formr
	url = https://github.com/rubenarslan/formr
[submodule "rmdpartials"]
	path = rmdpartials
	url = https://github.com/rubenarslan/rmdpartials
